rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isStringOrMissing(field) {
      return !(field in request.resource.data) || request.resource.data[field] is string;
    }

    function isBoolOrMissing(field) {
      return !(field in request.resource.data) || request.resource.data[field] is bool;
    }

    function isListOrMissing(field) {
      return !(field in request.resource.data) || request.resource.data[field] is list;
    }

    function validShortText(field, max) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is string && request.resource.data[field].size() <= max);
    }

    function validUsername() {
      return request.resource.data.username is string
        && request.resource.data.username.size() >= 2
        && request.resource.data.username.size() <= 30;
    }

    function validUserProfile() {
      return validUsername()
        && validShortText('displayName', 50)
        && validShortText('bio', 180)
        && validShortText('avatarUrl', 3000)
        && isBoolOrMissing('isCreator')
        && validShortText('creatorTag', 30)
        && isListOrMissing('followers')
        && isListOrMissing('following');
    }

    function validPostCreate() {
      return signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.caption is string
        && request.resource.data.caption.size() <= 2200
        && validShortText('username', 40)
        && validShortText('avatarUrl', 3000)
        && validShortText('imageUrl', 3000)
        && validShortText('imageData', 1500000)
        && isBoolOrMissing('isStory')
        && request.resource.data.likesCount == 0
        && request.resource.data.commentsCount == 0
        && request.resource.data.likedBy is list
        && request.resource.data.savedBy is list;
    }

    function validPostUpdate() {
      return signedIn()
        && (
          resource.data.userId == request.auth.uid
          || request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['likedBy', 'likesCount', 'savedBy', 'commentsCount', 'commentPreview'])
        )
        && (!(request.resource.data.caption is string) || request.resource.data.caption.size() <= 2200);
    }

    function conversationIdIsValid(conversationId) {
      return signedIn() && conversationId.matches('.*' + request.auth.uid + '.*');
    }

    // Users are public-readable to logged-in users for search, profiles, creator cards, etc.
    // Users can only create/update/delete their own user document.
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) && validUserProfile();
      allow update: if isOwner(userId) && validUserProfile();
      allow delete: if isOwner(userId);
    }

    // Posts are readable to logged-in users.
    // Only owner can create/delete. Non-owners may only update engagement fields.
    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if validPostCreate();
      allow update: if validPostUpdate();
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow update: if false;
        allow delete: if signedIn() && resource.data.userId == request.auth.uid;
      }
    }

    // Conversations are visible only to participants.
    match /conversations/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && validShortText('lastMessage', 1000);
      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants
        && validShortText('lastMessage', 1000);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn()
          && exists(/databases/$(database)/documents/conversations/$(conversationId))
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if signedIn()
          && request.resource.data.fromUserId == request.auth.uid
          && request.resource.data.toUserId is string
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && exists(/databases/$(database)/documents/conversations/$(conversationId))
          && request.resource.data.toUserId in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow update: if signedIn()
          && request.auth.uid == resource.data.toUserId
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);
        allow delete: if false;
      }
    }

    // Notifications can only be read/updated/deleted by the recipient.
    // Logged-in users can create notifications to other users for likes/follows/comments.
    match /notifications/{notificationId} {
      allow read: if signedIn() && resource.data.toUserId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 240
        && request.resource.data.read == false;
      allow update: if signedIn()
        && resource.data.toUserId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);
      allow delete: if signedIn() && resource.data.toUserId == request.auth.uid;
    }

    // Waitlist: public can submit, but nobody can read it from frontend.
    // IMPORTANT: this means client-side duplicate checks against waitlist will fail.
    match /waitlist/{entryId} {
      allow create: if request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 120
        && validShortText('name', 60)
        && validShortText('phone', 25)
        && validShortText('role', 40)
        && isBoolOrMissing('smsConsent')
        && request.resource.data.source == 'waitlist.html';
      allow read, update, delete: if false;
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
